{
    "name": "vongola12324/laravel-color-hash",
    "description": "ColorHash Library for Laravel 5.0+",
    "type": "library",
    "license": "MIT",
    "keywords":[
	    "laravel", "color", "hash"
    ],
    "homepage": "https://github.com/vongola12324/laravel-color-hash",
    "authors": [
        {
            "name": "Vongola",
            "email": "vongola12324@coder.tw"
        }
    ],
    "require": {
        "php": ">=8.2",
        "illuminate/support":"^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "3.* || 4.*",
        "phpunit/phpunit": "^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "php-coveralls/php-coveralls": "^2.0"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": [
            "phpstan analyse",
            "phpcs src/"
        ]
    },
    "autoload": {
        "psr-4": {
            "Vongola\\ColorHash\\": "src/"
        }
    },
    "extra": {
        "component": "package",
        "laravel": {
            "providers": [
                "Vongola\\ColorHash\\ColorHashServiceProvider"
            ],
            "aliases": {
                "ColorHash": "Vongola\\ColorHash\\Facades\\ColorHashFacade"
            }
        }
    }
}
